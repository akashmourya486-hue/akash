<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Akash Clothing</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
    }

    body{
      font-family:'Poppins',sans-serif;
      background:#f7f8fc;
      color:#222;
      overflow-x:hidden;
    }

    a{
      text-decoration:none;
      color:inherit;
    }

    img{
      width:100%;
      display:block;
    }

    .container{
      width:92%;
      max-width:1200px;
      margin:auto;
    }

    header{
      background:linear-gradient(135deg,#111827,#1f2937);
      color:white;
      padding:24px 0;
      position:sticky;
      top:0;
      z-index:100;
      box-shadow:0 4px 15px rgba(0,0,0,0.1);
    }

    .header-content{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:20px;
    }

    .logo h1{
      font-size:28px;
      font-weight:700;
    }

    .logo p{
      font-size:14px;
      opacity:0.8;
      margin-top:4px;
    }

    .location{
      font-size:14px;
      background:rgba(255,255,255,0.12);
      padding:10px 14px;
      border-radius:12px;
    }

    .hero{
      padding:40px 0 20px;
      text-align:center;
    }

    .hero h2{
      font-size:32px;
      margin-bottom:10px;
      color:#111827;
    }

    .hero p{
      color:#555;
      max-width:700px;
      margin:auto;
      line-height:1.6;
    }

    .filters{
      display:flex;
      gap:12px;
      flex-wrap:wrap;
      justify-content:center;
      margin:30px 0;
    }

    .filter-btn{
      border:none;
      background:white;
      padding:10px 18px;
      border-radius:999px;
      cursor:pointer;
      font-weight:500;
      transition:0.3s;
      box-shadow:0 4px 10px rgba(0,0,0,0.05);
    }

    .filter-btn.active,
    .filter-btn:hover{
      background:#111827;
      color:white;
    }

    .products{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(230px,1fr));
      gap:22px;
      padding-bottom:120px;
    }

    .product-card{
      background:white;
      border-radius:22px;
      overflow:hidden;
      box-shadow:0 10px 25px rgba(0,0,0,0.07);
      transition:0.3s ease;
      position:relative;
    }

    .product-card:hover{
      transform:translateY(-5px);
    }

    .product-info{
      padding:18px;
    }

    .category{
      font-size:12px;
      color:#6b7280;
      margin-bottom:8px;
      text-transform:uppercase;
      letter-spacing:1px;
    }

    .product-name{
      font-size:18px;
      font-weight:600;
      margin-bottom:8px;
    }

    .description{
      font-size:13px;
      color:#666;
      margin-bottom:14px;
      line-height:1.5;
    }

    .price{
      font-size:20px;
      font-weight:700;
      color:#111827;
      margin-bottom:14px;
    }

    .add-btn{
      width:100%;
      border:none;
      background:#111827;
      color:white;
      padding:12px;
      border-radius:12px;
      cursor:pointer;
      font-weight:600;
      transition:0.3s;
    }

    .add-btn:hover{
      background:#000;
    }

    .cart-floating{
      position:fixed;
      right:18px;
      bottom:90px;
      width:65px;
      height:65px;
      border-radius:50%;
      background:#111827;
      color:white;
      display:flex;
      align-items:center;
      justify-content:center;
      font-size:26px;
      cursor:pointer;
      z-index:999;
      box-shadow:0 10px 25px rgba(0,0,0,0.2);
    }

    .cart-count{
      position:absolute;
      top:-4px;
      right:-4px;
      background:#ef4444;
      width:24px;
      height:24px;
      border-radius:50%;
      display:flex;
      align-items:center;
      justify-content:center;
      font-size:12px;
      font-weight:700;
    }

    .cart-modal{
      position:fixed;
      inset:0;
      background:rgba(0,0,0,0.5);
      display:none;
      justify-content:flex-end;
      z-index:1000;
    }

    .cart-modal.active{
      display:flex;
    }

    .cart-content{
      width:100%;
      max-width:420px;
      background:white;
      height:100%;
      overflow-y:auto;
      padding:24px;
      animation:slideIn .3s ease;
    }

    @keyframes slideIn{
      from{
        transform:translateX(100%);
      }
      to{
        transform:translateX(0);
      }
    }

    .cart-header{
      display:flex;
      justify-content:space-between;
      align-items:center;
      margin-bottom:24px;
    }

    .close-cart{
      font-size:28px;
      cursor:pointer;
    }

    .cart-item{
      display:flex;
      gap:14px;
      margin-bottom:20px;
      border-bottom:1px solid #eee;
      padding-bottom:18px;
    }

    .cart-item img{
      width:85px;
      height:85px;
      object-fit:cover;
      border-radius:12px;
    }

    .cart-item-info{
      flex:1;
    }

    .cart-item-name{
      font-weight:600;
      margin-bottom:6px;
    }

    .cart-item-price{
      color:#555;
      font-size:14px;
      margin-bottom:10px;
    }

    .quantity-controls{
      display:flex;
      align-items:center;
      gap:10px;
      margin-bottom:8px;
    }

    .qty-btn{
      width:28px;
      height:28px;
      border:none;
      border-radius:8px;
      background:#111827;
      color:white;
      cursor:pointer;
    }

    .remove-btn{
      border:none;
      background:none;
      color:#ef4444;
      cursor:pointer;
      font-size:13px;
    }

    .cart-total{
      font-size:22px;
      font-weight:700;
      margin-top:18px;
      margin-bottom:20px;
    }

    .checkout-form{
      display:flex;
      flex-direction:column;
      gap:14px;
    }

    .checkout-form input,
    .checkout-form textarea{
      width:100%;
      padding:14px;
      border-radius:12px;
      border:1px solid #ddd;
      font-family:inherit;
      resize:none;
    }

    .place-order-btn{
      border:none;
      background:#16a34a;
      color:white;
      padding:14px;
      border-radius:14px;
      font-size:16px;
      font-weight:600;
      cursor:pointer;
      transition:0.3s;
    }

    .place-order-btn:hover{
      background:#15803d;
    }

    .empty-cart{
      text-align:center;
      color:#666;
      padding:50px 0;
    }

    .success-message{
      background:#dcfce7;
      color:#166534;
      padding:14px;
      border-radius:12px;
      margin-bottom:18px;
      display:none;
      font-size:14px;
    }

    .whatsapp-float{
      position:fixed;
      bottom:18px;
      right:18px;
      background:#25D366;
      color:white;
      padding:14px 18px;
      border-radius:999px;
      font-weight:600;
      box-shadow:0 8px 20px rgba(0,0,0,0.18);
      z-index:999;
    }

    footer{
      background:#111827;
      color:white;
      padding:30px 0;
      text-align:center;
      margin-top:40px;
    }

    footer p{
      opacity:0.8;
      font-size:14px;
      line-height:1.8;
    }

    @media(max-width:500px){

      .logo h1{
        font-size:22px;
      }

      .hero h2{
        font-size:26px;
      }

      .cart-content{
        max-width:100%;
      }
    }
  </style>
</head>

<body>

  <header>
    <div class="container header-content">
      <div class="logo">
        <h1>Akash Clothing</h1>
        <p>Premium fashion delivered to your doorstep</p>
      </div>

      <div class="location">
        📍 Varanasi, UP
      </div>
    </div>
  </header>

  <section class="hero container">
    <h2>Affordable Fashion Collection</h2>
    <p>
      Explore stylish shirts, oversized t-shirts, and combo packs for men.
      Order online easily and we’ll contact you on WhatsApp to confirm your order.
    </p>
  </section>

  <div class="container">

    <div class="filters">
      <button class="filter-btn active" data-category="all">All</button>
      <button class="filter-btn" data-category="shirt">Shirts</button>
      <button class="filter-btn" data-category="oversized tshirt">Oversized T-Shirts</button>
    </div>

    <div class="products" id="productGrid"></div>

  </div>

  <!-- CART BUTTON -->

  <div class="cart-floating" id="cartBtn">
    🛒
    <div class="cart-count" id="cartCount">0</div>
  </div>

  <!-- CART MODAL -->

  <div class="cart-modal" id="cartModal">

    <div class="cart-content">

      <div class="cart-header">
        <h2>Your Cart</h2>
        <span class="close-cart" id="closeCart">&times;</span>
      </div>

      <div class="success-message" id="successMessage">
        Order placed! Akash Clothing will contact you on WhatsApp to confirm.
        <br><br>
        <a href="https://wa.me/+918081067231" target="_blank">
          Click here to chat on WhatsApp
        </a>
      </div>

      <div id="cartItems"></div>

      <div class="cart-total" id="cartTotal">
        Total: $0
      </div>

      <form
        class="checkout-form"
        id="orderForm"
        action="https://formspree.io/f/xkoenngj"
        method="POST"
      >

        <input type="text" name="Customer Name" placeholder="Customer Name" required>

        <input type="tel" name="Phone Number" placeholder="Phone Number" required>

        <textarea name="Delivery Address" rows="3" placeholder="Delivery Address" required></textarea>

        <textarea name="Special Instructions" rows="3" placeholder="Any special instructions?"></textarea>

        <input type="hidden" name="Order Summary" id="orderSummary">

        <button type="submit" class="place-order-btn">
          Place Order
        </button>

      </form>

    </div>

  </div>

  <!-- WHATSAPP BUTTON -->

  <a
    href="https://wa.me/+918081067231"
    target="_blank"
    class="whatsapp-float"
  >
    WhatsApp
  </a>

  <footer>
    <div class="container">
      <p>
        © 2026 Akash Clothing <br>
        Orders are confirmed manually via WhatsApp after submission.
      </p>
    </div>
  </footer>

  <script>

    const products = [

      {
        id:1,
        name:"Cotton Blend Shirt",
        category:"shirt",
        price:5.1,
        image:"https://i.ibb.co/PsphRWG8/f6f0fd6a087c42e113d0d00355b461f8.jpg",
        description:"Premium cotton blend shirt for everyday comfort."
      },

      {
        id:2,
        name:"Oversized T-Shirt",
        category:"oversized tshirt",
        price:4.5,
        image:"https://i.ibb.co/cc6cJqqZ/384ecbae36f07d8735e5dfad3eacff9a.jpg",
        description:"Trendy oversized t-shirt with relaxed fit."
      },

      {
        id:3,
        name:"Formal Combos For Men (Pack of 5)",
        category:"shirt",
        price:7.0,
        image:"https://i.ibb.co/Ld9nZTbM/626a156a38149a38ece749bb93ea2cfc.jpg",
        description:"Stylish formal combo pack perfect for office wear."
      }

    ];

    const productGrid = document.getElementById("productGrid");
    const cartCount = document.getElementById("cartCount");
    const cartItems = document.getElementById("cartItems");
    const cartTotal = document.getElementById("cartTotal");
    const cartModal = document.getElementById("cartModal");
    const cartBtn = document.getElementById("cartBtn");
    const closeCart = document.getElementById("closeCart");
    const orderSummary = document.getElementById("orderSummary");
    const successMessage = document.getElementById("successMessage");

    let cart = JSON.parse(localStorage.getItem("cart")) || [];

    function renderProducts(category="all"){

      productGrid.innerHTML="";

      const filtered = category === "all"
      ? products
      : products.filter(p => p.category === category);

      filtered.forEach(product => {

        productGrid.innerHTML += `

          <div class="product-card">

            <img
              src="${product.image}"
              alt="${product.name}"
              loading="lazy"
            >

            <div class="product-info">

              <div class="category">${product.category}</div>

              <div class="product-name">${product.name}</div>

              <div class="description">${product.description}</div>

              <div class="price">$${product.price.toFixed(2)}</div>

              <button class="add-btn" onclick="addToCart(${product.id})">
                Add To Cart
              </button>

            </div>

          </div>

        `;
      });
    }

    function addToCart(id){

      const item = cart.find(p => p.id === id);

      if(item){
        item.quantity += 1;
      }else{
        const product = products.find(p => p.id === id);
        cart.push({...product, quantity:1});
      }

      saveCart();
      renderCart();

      cartBtn.animate([
        {transform:'scale(1)'},
        {transform:'scale(1.15)'},
        {transform:'scale(1)'}
      ],{
        duration:300
      });
    }

    function renderCart(){

      cartItems.innerHTML = "";

      if(cart.length === 0){

        cartItems.innerHTML = `
          <div class="empty-cart">
            Your cart is empty
          </div>
        `;

      }

      let total = 0;
      let totalItems = 0;

      cart.forEach(item => {

        const subtotal = item.price * item.quantity;

        total += subtotal;
        totalItems += item.quantity;

        cartItems.innerHTML += `

          <div class="cart-item">

            <img
              src="${item.image}"
              alt="${item.name}"
              loading="lazy"
            >

            <div class="cart-item-info">

              <div class="cart-item-name">
                ${item.name}
              </div>

              <div class="cart-item-price">
                $${item.price.toFixed(2)}
              </div>

              <div class="quantity-controls">

                <button class="qty-btn" onclick="changeQty(${item.id}, -1)">-</button>

                <span>${item.quantity}</span>

                <button class="qty-btn" onclick="changeQty(${item.id}, 1)">+</button>

              </div>

              <div style="font-size:14px; margin-bottom:8px;">
                Subtotal: $${subtotal.toFixed(2)}
              </div>

              <button class="remove-btn" onclick="removeItem(${item.id})">
                Remove
              </button>

            </div>

          </div>

        `;
      });

      cartCount.textContent = totalItems;
      cartTotal.textContent = `Total: $${total.toFixed(2)}`;

      const summary = cart.map(item =>
        `${item.name} x ${item.quantity} = $${(item.price * item.quantity).toFixed(2)}`
      ).join('\n');

      orderSummary.value = `
======== NEW ORDER ========

ORDER ITEMS:
${summary}

GRAND TOTAL: $${total.toFixed(2)}

==========================
      `;

      saveCart();
    }

    function changeQty(id, change){

      const item = cart.find(p => p.id === id);

      if(!item) return;

      item.quantity += change;

      if(item.quantity <= 0){
        cart = cart.filter(p => p.id !== id);
      }

      renderCart();
    }

    function removeItem(id){

      cart = cart.filter(p => p.id !== id);

      renderCart();
    }

    function saveCart(){

      localStorage.setItem("cart", JSON.stringify(cart));
    }

    cartBtn.addEventListener("click", () => {
      cartModal.classList.add("active");
    });

    closeCart.addEventListener("click", () => {
      cartModal.classList.remove("active");
    });

    cartModal.addEventListener("click", (e) => {

      if(e.target === cartModal){
        cartModal.classList.remove("active");
      }
    });

    document.querySelectorAll(".filter-btn").forEach(btn => {

      btn.addEventListener("click", () => {

        document.querySelectorAll(".filter-btn")
        .forEach(b => b.classList.remove("active"));

        btn.classList.add("active");

        renderProducts(btn.dataset.category);
      });
    });

    document.getElementById("orderForm")
    .addEventListener("submit", function(){

      setTimeout(() => {

        cart = [];
        saveCart();
        renderCart();

        successMessage.style.display = "block";

      },1000);
    });

    renderProducts();
    renderCart();

  </script>

</body>
</html>
